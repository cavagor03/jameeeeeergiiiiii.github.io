    </trkseg>
  </trk>

  <trk>
    <name>День 3: ТС Джурла — ущ. Хапхал — Генеральское</name>
    <trkseg>
      <trkpt lat="44.7689" lon="34.4302"><ele>890</ele></trkpt>
      <trkpt lat="44.7831" lon="34.4442"><ele>930</ele></trkpt>
