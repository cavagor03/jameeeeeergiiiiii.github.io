    </trkseg>
  </trk>

  <trk>
    <name>День 5: Ай-Алексий — плато Тырке — ТС Вост. Суат</name>
    <trkseg>
      <trkpt lat="44.8144" lon="34.4380"><ele>795</ele></trkpt>
      <trkpt lat="44.8231" lon="34.4411"><ele>850</ele></trkpt>
      <trkpt lat="44.8295" lon="34.4498"><ele>910</ele></trkpt>
