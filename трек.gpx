<?xml version="1.0" encoding="UTF-8"?>
<gpx version="1.1" creator="Gemini Hiking Planner 2026" xmlns="http://www.topografix.com/GPX/1/1">
  <metadata>
    <name>Скальный лабиринт Демерджи - Полноценный 7-дневный трек</name>
    <desc>Автономный научно-познавательный маршрут с 26 КП, плановыми и экстренными стоянками. Дистанция ~43.5 км.</desc>
    <author>
      <name>Академия Походных Навыков</name>
    </author>
  </metadata>

  <!-- ==================== ПУТЕВЫЕ ТОЧКИ: ОСНОВНЫЕ КП ==================== -->
  <wpt lat="44.7538" lon="34.3985">
    <name>КП 01: Старт Лучисте</name>
    <desc>Информационный щит на северной окраине с. Лучистое у конных баз. Точка старта и проверки снаряжения.</desc>
    <type>Control Point</type>
  </wpt>
  
  <wpt lat="44.7512" lon="34.4069">
    <name>КП 02: Кр. Фуна</name>
    <desc>Руины средневековой крепости княжества Феодоро (XV век). КП у основания северо-восточной оборонительной башни.</desc>
    <type>Historical</type>
  </wpt>

  <wpt lat="44.7545" lon="34.4095">
    <name>КП 03: Камень Разбитое Сердце</name>
    <desc>Гигантский валун-конгломерат, расколотый пополам обвалом 1894 года. Проход насквозь обязателен.</desc>
    <type>Nature</type>
  </wpt>

  <wpt lat="44.7570" lon="34.4072">
    <name>КП 04: Долина Привидений</name>
    <desc>Вход в нижний скальный лабиринт. Ориентир — отдельно стоящий скальный пик "Чертов палец".</desc>
    <type>Nature</type>
  </wpt>

  <wpt lat="44.7661" lon="34.4038">
    <name>КП 05: Проход Хой-Кая</name>
    <desc>Выход из крутого лесного кулуара на открытую бровку плато. Панорамная точка.</desc>
    <type>Control Point</type>
  </wpt>

  <wpt lat="44.7645" lon="34.4111">
    <name>КП 06: Скала Екатерина</name>
    <desc>Мощный конгломератовый выступ, напоминающий профиль императрицы. Опасный обрыв, осторожно при ветре!</desc>
    <type>Nature</type>
  </wpt>

  <wpt lat="44.7558" lon="34.4158">
    <name>КП 07: Вершина Юж. Демерджи</name>
    <desc>Высшая точка южного плато (1239 м). Металлическая вышка-триангулятор.</desc>
    <type>Peak</type>
  </wpt>

  <wpt lat="44.7684" lon="34.4277">
    <name>КП 08: Верхний Джурла</name>
    <desc>Сглаженное скальное русло ручья Алака перед каскадным сбросом. Маркер на вековом буке у воды.</desc>
    <type>Waterfall</type>
  </wpt>

  <wpt lat="44.7689" lon="34.4302">
    <name>КП 09: Горное озеро Джурла</name>
    <desc>Искусственный водоем, старая бетонная плотина. Место сбора группы.</desc>
    <type>Nature</type>
  </wpt>

  <wpt lat="44.7831" lon="34.4442">
    <name>КП 10: Верхний створ Хапхала</name>
    <desc>Начало резкого технического спуска в каньон. Крутизна склона до 35 градусов, беречь колени.</desc>
    <type>Control Point</type>
  </wpt>

  <wpt lat="44.7925" lon="34.4533">
    <name>КП 11: Каскад Девичьи косы</name>
    <desc>Серия ступенчатых плоских водопадов в верховьях реки Восточный Улу-Узень. Маркер на бревне через русло.</desc>
    <type>Waterfall</type>
  </wpt>

  <wpt lat="44.8053" lon="34.4594">
    <name>КП 12: Водопад Джур-Джур</name>
    <desc>Главный экскурсионный объект. Мощный 15-метровый водопад. КП на перилах смотровой площадки.</desc>
    <type>Waterfall</type>
  </wpt>

  <wpt lat="44.8071" lon="34.4578">
    <name>КП 13: Пещера Джур-Джур</name>
    <desc>Дикий темный грот на правом борту ущелья. Входной маркер на скале у входа.</desc>
    <type>Cave</type>
  </wpt>

  <wpt lat="44.8142" lon="34.4375">
    <name>КП 14: Родник Ай-Алексий</name>
    <desc>Культовый двухтрубный источник-каптаж в каменном гроте. Пополнение запасов воды на плато!</desc>
    <type>Water</type>
  </wpt>

  <wpt lat="44.8231" lon="34.4411">
    <name>КП 15: Дерево-Навигатор</name>
    <desc>Старый раскидистый дуб на развилке лесовозных дорог между Караби и Тырке.</desc>
    <type>Control Point</type>
  </wpt>

  <wpt lat="44.8295" lon="34.4498">
    <name>КП 16: Партизанская землянка</name>
    <desc>Военно-исторический памятник. Реконструкция укрытия отряда И.Г. Генова.</desc>
    <type>Historical</type>
  </wpt>

  <wpt lat="44.8211" lon="34.4214">
    <name>КП 17: Скала Бору-Кая</name>
    <desc>Точка окончания крутого лесного подъема. Выход на ветреное высокогорное плато Тырке.</desc>
    <type>Nature</type>
  </wpt>

  <wpt lat="44.8115" lon="34.4269">
    <name>КП 18: Гора Хаплузи-Кая</name>
    <desc>Скала-мыс, вертикально обрывающаяся в Хапхальский каньон с севера. Вид на трек 3-го дня.</desc>
    <type>Peak</type>
  </wpt>

  <wpt lat="44.8288" lon="34.4095">
    <name>КП 19: Граничный столб</name>
    <desc>Бетонный геодезический и лесной маркер на стыке Долгоруковской яйлы и Тырке.</desc>
    <type>Control Point</type>
  </wpt>

  <wpt lat="44.8344" lon="34.4011">
    <name>КП 20: Истоки Бурульчи</name>
    <desc>Выход подземной реки из карстовой воронки на поверхность. Начало зеленой долины.</desc>
    <type>Water</type>
  </wpt>

  <wpt lat="44.8195" lon="34.3855">
    <name>КП 21: Партизанский аэродром</name>
    <desc>Плоское поле на хребте Таш-Хабах. Памятник-звезда летчикам и партизанам ВОВ.</desc>
    <type>Historical</type>
  </wpt>

  <wpt lat="44.7812" lon="34.3944">
    <name>КП 22: Пещера МАН</name>
    <desc>Карстовая пещера. Входной грот открыт, внутренний вертикальный колодец (30м) без спелео-снаряжения запрещен!</desc>
    <type>Cave</type>
  </wpt>

  <wpt lat="44.8055" lon="34.3795">
    <name>КП 23: Скала Козырек</name>
    <desc>Одиночный скальный козырек над Курлюкской балкой. Одинокий тис на краю.</desc>
    <type>Nature</type>
  </wpt>

  <wpt lat="44.8011" lon="34.3688">
    <name>КП 24: Скальный проход Замана</name>
    <desc>Природные каменные ворота — тропа зажата между двух огромных глыб известняка.</desc>
    <type>Control Point</type>
  </wpt>

  <wpt lat="44.7578" lon="34.3442">
    <name>КП 25: Обелиск строителям дороги</name>
    <desc>Исторический памятник XIX века в лесу у старой дороги. Конец лесной части.</desc>
    <type>Historical</type>
  </wpt>

  <wpt lat="44.7552" lon="34.3418">
    <name>КП 26: Финиш Ангарский перевал</name>
    <desc>Пост МЧС, троллейбусная остановка на трассе Симферополь-Алушта. Финиш маршрута.</desc>
    <type>Control Point</type>
  </wpt>

  <!-- ==================== ПЛАНОВЫЕ СТОЯНКИ ( CAMPING ) ==================== -->
  <wpt lat="44.7712" lon="34.3995">
    <name>CAMP 1: Поляна МАН</name>
    <desc>Плановая стоянка 1. Огромная поляна под Северной Демерджи. Родник ниже в овраге. Активность: Мастер-класс по узлам.</desc>
    <type>Camping</type>
  </wpt>

  <wpt lat="44.7678" lon="34.4295">
    <name>CAMP 2: ТС Джурла</name>
    <desc>Плановая стоянка 2. Оборудованное кострище у озера. Родник в 100м к югу. Активность: Акустический тренинг и вечер легенд.</desc>
    <type>Camping</type>
  </wpt>

  <wpt lat="44.8112" lon="34.4611">
    <name>CAMP 3: ТС Генеральское</name>
    <desc>Плановая стоянка 3. Поляны на окраине села у реки. Легкий доступ к магазинам. Активность: Кулинарный баттл на горелках.</desc>
    <type>Camping</type>
  </wpt>

  <wpt lat="44.8144" lon="34.4380">
    <name>CAMP 4: ТС Ай-Алексий</name>
    <desc>Плановая стоянка 4. Лесная стоянка прямо у мощного родника. Активность: Ночной квест Партизанский радист.</desc>
    <type>Camping</type>
  </wpt>

  <wpt lat="44.8322" lon="34.3985">
    <name>CAMP 5: ТС Восточный Суат</name>
    <desc>Плановая стоянка 5. Глубокая закрытая котловина у ручья. Защита от ветра. Активность: Создание Карты памяти.</desc>
    <type>Camping</type>
  </wpt>

  <wpt lat="44.8095" lon="34.3611">
    <name>CAMP 6: ТС Курлюк-Су</name>
    <desc>Плановая стоянка 6. Финальная стоянка в лесной балке у ручья. Активность: Посвящение в рыцари и прощальная свеча.</desc>
    <type>Camping</type>
  </wpt>

  <!-- ==================== ЭКСТРЕННЫЕ СТОЯНКИ ( EMERGENCY ) ==================== -->
  <wpt lat="44.7648" lon="34.4231">
    <name>EMERGENCY A: Седловина Демерджи</name>
    <desc>ЭКСТРЕННАЯ СТОЯНКА. Плоская перемычка. Воды нет. Использовать только при резком шторме/тумане, чтобы не идти по обрывам Южной Демерджи.</desc>
    <type>Emergency Camp</type>
  </wpt>

  <wpt lat="44.7985" lon="34.4552">
    <name>EMERGENCY B: Грот Хапхала</name>
    <desc>ЭКСТРЕННАЯ СТОЯНКА. Скальный навес на левом борту ущелья Хапхал. Спасает от внезапного паводка или ливня. Место под 2-3 палатки без растяжек.</desc>
    <type>Emergency Camp</type>
  </wpt>

  <wpt lat="44.8190" lon="34.4310">
    <name>EMERGENCY C: Опушка под Тырке</name>
    <desc>ЭКСТРЕННАЯ СТОЯНКА. Граница леса перед взлетом на плато Тырке. Если на плато идет гроза — наверх не подниматься, экстренно вставать лагерей здесь!</desc>
    <type>Emergency Camp</type>
  </wpt>

  <wpt lat="44.8215" lon="34.3912">
    <name>EMERGENCY D: Поляна Таш-Хабах</name>
    <desc>ЭКСТРЕННАЯ СТОЯНКА. Небольшая поляна с кострищем на хребте в буковом лесу. Спасает от ураганного ветра, который часто дует на открытой Долгоруковской яйле.</desc>
    <type>Emergency Camp</type>
  </wpt>


  <!-- ==================== ЛИНИИ ТРЕКА ПО ДНЯМ ==================== -->
  <trk>
    <name>День 1: Лучисте — Поляна МАН</name>
