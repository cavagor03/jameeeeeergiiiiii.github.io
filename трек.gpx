    </trkseg>
  </trk>

  <trk>
    <name>День 4: Генеральское — Родник Ай-Алексий</name>
    <trkseg>
      <trkpt lat="44.8112" lon="34.4611"><ele>410</ele></trkpt>
      <trkpt lat="44.8142" lon="34.4375"><ele>790</ele></trkpt>
