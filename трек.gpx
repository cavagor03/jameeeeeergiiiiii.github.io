    </trkseg>
  </trk>

  <trk>
    <name>День 6: ТС Вост. Суат — хр. Таш-Хабах — ТС Курлюк-Су</name>
    <trkseg>
      <trkpt lat="44.8322" lon="34.3985"><ele>960</ele></trkpt>
